# RunForge 后端环境变量
# 复制此文件为 .env 并填入真实值

# ── 应用 ────────────────────────────────
APP_NAME=RunForge API
APP_VERSION=1.0.0
DEBUG=true

# ── OCR 图片识别（v2.0+）────────────────
# 通义千问（优先使用，成本低）
# 获取 Key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# OpenAI GPT-4o（备份，通义千问失败时使用）
OPENAI_API_KEY=

# ── Supabase（v2.0 云端DB，v1.0 可留空）──
SUPABASE_URL=
SUPABASE_KEY=

# ── CORS ────────────────────────────────
# 生产环境改为具体域名，如 https://runforge.app
ALLOWED_ORIGINS=["*"]
