# RunForge 后端环境变量
# 复制此文件为 .env 并填入真实值

# ── 应用 ────────────────────────────────
APP_NAME=RunForge API
APP_VERSION=1.0.0
DEBUG=true

# ── OpenAI（v2.0 OCR 功能，v1.0 可留空）──
OPENAI_API_KEY=

# ── Supabase（v2.0 云端DB，v1.0 可留空）──
SUPABASE_URL=
SUPABASE_KEY=

# ── CORS ────────────────────────────────
# 生产环境改为具体域名，如 https://runforge.app
ALLOWED_ORIGINS=["*"]
